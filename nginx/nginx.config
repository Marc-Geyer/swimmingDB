user nginx;
worker_processes auto;

events {
    worker_connections 1024;
}

http {
    include       mime.types;
    default_type  application/octet-stream;
    sendfile      on;

    # Define the upstream for your Django ASGI server
    upstream django_upstream {
        server swim-pro:8000;  # Django/Gunicorn container
    }

    server {
        listen 80;

        # --- Static Files ---
        location /static/ {
            alias /static/;
            # Optional: Add caching headers for static files
            expires 30d;
            add_header Cache-Control "public, immutable";
        }

        # --- WebSocket Support (CRITICAL FOR CHANNELS) ---
        # Match any path starting with /ws/ (adjust if your paths differ)
        location /ws/ {
            proxy_pass http://django_upstream;

            # These headers are required for WebSocket handshake
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";

            # Standard proxy headers
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;

            # Increase timeout to prevent disconnection during idle periods
            proxy_read_timeout 86400s;
        }

        # --- Regular HTTP Requests ---
        location / {
            proxy_pass http://django_upstream;

            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }
}